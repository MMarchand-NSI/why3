let partition (tab: array int) (a: int) (b: int) : int
  requires { 0 <= a < b <= length tab }
  ensures { a <= result < b }
  ensures { permut_all (old tab) tab }
  ensures { permut_sub (old tab) tab a b }
  ensures { tab[result] = (old tab)[a] }
  ensures { forall i. a <= i < result -> tab[i] < tab[result] }
  ensures { forall i. result < i < b -> tab[i] >= tab[result] }
=
  let pivot = tab[a] in
  let ref ipivot = a in
  
  for i = a+1 to b-1 do
    invariant { 0 <= a <= ipivot < i <= b <= length tab }
    invariant { permut_all (old tab) tab }
    invariant { permut_sub (old tab) tab a b }
    invariant { tab[a] = pivot }
    invariant { forall k. a < k <= ipivot -> tab[k] < pivot }
    invariant { forall k. ipivot < k < i -> tab[k] >= pivot }
    
    if tab[i] < pivot then begin
      ipivot := ipivot + 1;
      swap_local tab ipivot i a b
    end
  done;
  
  swap_local tab a ipivot a b;
  ipivot


axiom sorted_partition_concat:
  forall a: array int, l p r: int.
  0 <= l <= p < r <= length a ->
  sorted_sub a l p ->
  sorted_sub a (p+1) r ->
  (forall i. l <= i < p -> a[i] < a[p]) ->
  (forall i. p < i < r -> a[i] >= a[p]) ->
  sorted_sub a l r

let rec quicksort (tab: array int) (a: int) (b: int) : unit
  requires { 0 <= a <= b <= length tab }
  ensures { sorted_sub tab a b }
  ensures { permut_sub (old tab) tab a b }
  variant { b - a }
=
  if a + 1 >= b then begin
    assert { sorted_sub tab a b };  (* Intervalle vide/singleton déjà trié *)
    assert { permut_sub tab tab a b };  (* Permutation identité *)
    return
  end;
  
  label L in
  let p = partition tab a b in
  
  assert { permut_sub (tab at L) tab a b };
  assert { forall i. a <= i < p -> tab[i] < tab[p] };
  assert { forall i. p < i < b -> tab[i] >= tab[p] };
  
  label M in
  quicksort tab a p;
  
  assert { permut_sub (tab at M) tab a p };
  assert { sorted_sub tab a p };
  assert { tab[p] = (tab at M)[p] };
  
  label N in  
  quicksort tab (p + 1) b;
  
  assert { permut_sub (tab at N) tab (p+1) b };
  assert { sorted_sub tab (p+1) b };
  assert { forall i. a <= i < p -> tab[i] < tab[p] };
  assert { forall i. p < i < b -> tab[i] >= tab[p] }

end