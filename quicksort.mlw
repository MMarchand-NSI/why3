(** swaper dans l'intervalle [a, b) préserve les permutations 
C'est nécessaire car why3 ne fait pas le lien **)
let swap_local (t: array int) (i j: int) (a b: int) : unit
  requires { 0 <= a <= i < b <= length t }
  requires { 0 <= a <= j < b <= length t }
  ensures { exchange (old t) t i j }
  ensures { permut_sub (old t) t a b }
=
  swap t i j

