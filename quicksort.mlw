(* -*- coding: utf-8 -*- *)

(* Faire tourner avec >4G RAM dispo mini *)
module Quicksort

use array.Array
use array.ArraySwap
use array.ArrayPermut
use array.IntArraySorted
use int.Int
use ref.Ref

