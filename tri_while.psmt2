;; "array'invariant"
(assert (par (a)
  (forall ((self (array a)))
    (! (<= 0 (length self)) :pattern ((length self)) ))))

;; "mixfix []"
(define-fun mixfix_lbrb (par (a)
  ((a1 (array a)) (i Int)) a
  (select (elts a1) i)))

;; "make"
(declare-fun make (par (a)
