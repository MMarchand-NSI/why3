        (and (<= l j) (< j u))
        (exchange
          a1
          (store (store a1 i (select a1 j)) j (select a1 i))
          l
          u
          i
          j))))))

;; "exchange"
(define-fun exchange1 (par (a)
  ((a1 (array a)) (a2 (array a)) (i Int) (j Int)) Bool
  (and
    (= (length a1) (length a2))
    (exchange (elts a1) (elts a2) 0 (length a1) i j))))

;; "permut"
(define-fun permut1 (par (a)
  ((a1 (array a)) (a2 (array a)) (l Int) (u Int)) Bool
  (and
    (= (length a1) (length a2))
    (and
      (and (<= 0 l) (<= l (length a1)))
      (and
        (and (<= 0 u) (<= u (length a1)))
        (permut (elts a1) (elts a2) l u))))))

;; "permut_sub"
(define-fun permut_sub (par (a)
  ((a1 (array a)) (a2 (array a)) (l Int) (u Int)) Bool
  (and
    (map_eq_sub (elts a1) (elts a2) 0 l)
    (and (permut1 a1 a2 l u) (map_eq_sub (elts a1) (elts a2) u (length a1))))))

;; "permut_all"
(define-fun permut_all (par (a)
  ((a1 (array a)) (a2 (array a))) Bool
  (and
    (= (length a1) (length a2))
    (permut (elts a1) (elts a2) 0 (length a1)))))

;; "exchange_permut_sub"
(assert (par (a)
  (forall ((a1 (array a)) (a2 (array a)) (i Int) (j Int) (l Int) (u Int))
    (=>
