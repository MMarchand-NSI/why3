  a) (array a)))

;; "make_spec"
(assert (par (a)
  (forall ((n Int) (v a))
    (=>
      (<= 0 n)
      (forall ((i Int))
        (=> (and (<= 0 i) (< i n)) (= (mixfix_lbrb (make n v) i) v)))))))

;; "make_spec"
(assert (par (a)
  (forall ((n Int) (v a)) (=> (<= 0 n) (= (length (make n v)) n)))))

;; "sorted_sub"
(define-fun sorted_sub ((a1 (Array Int Int)) (l Int) (u Int)) Bool
  (forall ((i1 Int) (i2 Int))
    (=>
      (and (<= l i1) (and (<= i1 i2) (< i2 u)))
      (<= (select a1 i1) (select a1 i2)))))

;; "sorted_sub"
(define-fun sorted_sub1 ((a1 (array Int)) (l Int) (u Int)) Bool
  (sorted_sub (elts a1) l u))

;; "sorted"
(define-fun sorted ((a1 (array Int))) Bool
  (sorted_sub (elts a1) 0 (length a1)))

