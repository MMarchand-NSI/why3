;; "map_eq_sub"
(define-fun map_eq_sub (par (a)
  ((a1 (Array Int a)) (a2 (Array Int a)) (l Int) (u Int)) Bool
  (forall ((i Int))
    (=> (and (<= l i) (< i u)) (= (select a1 i) (select a2 i))))))

;; "exchange"
(define-fun exchange (par (a)
  ((a1 (Array Int a)) (a2 (Array Int a)) (l Int) (u Int) (i Int) (j Int)) Bool
  (and
    (and (<= l i) (< i u))
    (and
      (and (<= l j) (< j u))
      (and
        (= (select a1 i) (select a2 j))
        (and
          (= (select a1 j) (select a2 i))
          (forall ((k Int))
            (=>
              (and (<= l k) (< k u))
              (=>
                (not (= k i))
                (=> (not (= k j)) (= (select a1 k) (select a2 k))))))))))))

