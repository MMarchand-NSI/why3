          (and (<= l j) (< j u))
          (=> (<= 0 l) (=> (<= u (length a1)) (permut_sub a1 a2 l u)))))))))

;; "permut_sub_trans"
(assert (par (a)
  (forall ((a1 (array a)) (a2 (array a)) (a3 (array a)) (l Int) (u Int))
    (=>
