      (=>
        (<= u (length a1))
        (=>
          (permut_sub a1 a2 l u)
          (=> (permut_sub a2 a3 l u) (permut_sub a1 a3 l u))))))))

;; "permut_sub_weakening"
(assert (par (a)
  (forall ((a1 (array a)) (a2 (array a)) (l1 Int) (u1 Int) (l2 Int) (u2 Int))
    (=>
