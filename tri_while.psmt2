;; "permut"
(define-fun permut (par (a)
  ((m1 (Array Int a)) (m2 (Array Int a)) (l Int) (u Int)) Bool
  (forall ((v a)) (= (occ v m1 l u) (occ v m2 l u)))))

;; "permut_trans"
(assert (par (a)
  (forall ((a1 (Array Int a)) (a2 (Array Int a)) (a3 (Array Int a)))
    (forall ((l Int) (u Int))
      (=> (permut a1 a2 l u) (=> (permut a2 a3 l u) (permut a1 a3 l u)))))))

