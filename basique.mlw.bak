why3  version 1.8.0
prover alt-ergo 2.6.0
*)

theory Basique

use int.Int
use int.Fact
use array.Array
use array.ArraySum
use array.ArraySwap

use ref.Ref

let concat (a: array int) (b: array int): (res: array int)
  ensures {forall j. 0<=j<length a -> a[j]=res[j]}
  ensures {forall j. 0<=j<length b -> b[j]=res[j+length a]}
=
  let na = length a in
  let nb = length b in
  let res = make (na+nb) 0 in
  for i=0 to na-1 do
    invariant { forall j. 0 <= j < i -> res[j] = a[j] }
    res[i] <- a[i]
  done;
  for i=0 to nb-1 do
    invariant { forall j. 0 <= j < na -> res[j] = a[j] } 
    invariant { forall j. 0 <= j < i  -> res[j + na] = b[j] }
    res[i+na] <- b[i]
  done;
  return res


let min (a: array int) : (res: int)
  requires {length a>0}
  ensures {exists i. 0 <= i < length a && res = a[i]}
  ensures {forall i. 0<=i<length a -> res <= a[i]}
=
  let n = length a in
  let ref res = a[0] in
  for i=1 to n-1 do
    invariant {exists j. 0 <= j < i && res = a[j]}
    invariant {forall j. 0<=j<i -> res<=a[j]}
    if a[i]<res then res := a[i]
  done;
  return res


let somme (a: array int) : (res: int)
  ensures { res = sum a 0 (length a) }
=
  let ref res = 0 in
  for i = 0 to length a - 1 do
    invariant { res = sum a 0 i }
    res := res + a[i]
  done;
  res



let factorielle(n: int) : (res: int)
  requires { n >= 0 }
  ensures {res = fact n}
=
  let ref res = 1 in
  for i=1 to n do
    invariant {res = fact (i-1)}
    res := res * i
  done;
  return res

let fois2(n: int) : (res: int)
  requires { n >= 0 }  (* Pré condition *)
  ensures {res = 2*n}  (* Post condition *)
= 
  let ref res = 0 in
  for i=1 to n do
    invariant {res = 2*(i-1)}
    res := res + 2
  done;
  return res


let contient (tab: array int) (elt: int) (a: int) (b: int) : bool
  requires { 0 <= a <= b <= length tab }
  ensures {result <-> exists i. a <= i < b && tab[i] = elt }
  ensures { not result -> forall i. a <= i < b -> tab[i] <> elt }

=
  for i=a to b - 1 do
    invariant { forall j. a <= j < i -> tab[j] <> elt }
    if tab[i] = elt then return true
  done;
  false

(**
renvoie r tel que tab[0, r) soit dédoublonné.
[r, length tab) contient les doublons
**)
let deduplication (tab: array int) : int
  ensures { 0<=result<=length tab }
  ensures {forall i j. 0<=i<j<result -> tab[i]<>tab[j]}
  ensures {forall i. 0<=i<length (old tab) -> exists j. 0<=j<result && (old tab)[i]=tab[j]}
= 
  let ref r = length tab in
  let ref i = 0 in
  while i<r do (*Si i atteint la région des doublons, on arrête*)
    invariant { 0<=i<=r<=length tab }
    invariant {forall j k. 0<=j<k<i -> tab[j]<>tab[k]}
    invariant {forall j. 0<=j<length (old tab) -> exists k. 0<=k<r && (old tab)[j]=tab[k]}
    variant { r - i }
    if contient tab tab[i] 0 i then begin
      r:=r-1; (* On fait une place *)
      (*On remplace le courant par le dernier inexploré sur lequel on a fait de la place*)
      swap tab r i
    end else 
      i := i + 1
  done;
  return r


lemma dedup_preservation:
  forall tab1 tab:array int, r1 i1 j:int.
  tab = tab1[r1 <- tab1[i1]] ->
  0 <= j < r1 < length tab1 ->
  tab[j] = tab1[j]

let deduplication2 (tab: array int) : int
  requires { length tab > 0 }
  ensures { 0 <= result <= length tab }
  ensures { forall i j. 0 <= i < j < result -> tab[i] <> tab[j] }
  ensures { forall i. 0 <= i < length (old tab) -> 
            exists j. 0 <= j < result /\ (old tab)[i] = tab[j] }
=
  let ghost old_tab = copy tab in
  let ref r = 0 in
  let ref i = 0 in
  while i < length tab do
    invariant { 0 <= r <= i <= length tab }
    invariant { forall j k. 0 <= j < k < r -> tab[j] <> tab[k] }
    invariant { forall j. 0 <= j < i -> exists k. 0 <= k < r /\ old_tab[j] = tab[k] }
    variant { length tab - i }
    if not (contient tab tab[i] 0 r) then begin
      tab[r] <- tab[i];
      r := r + 1
    end;
    i := i + 1
  done;
  r

  end